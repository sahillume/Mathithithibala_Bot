{
  "name": "Mathithibala_Bot",
  "description": "Professional WhatsApp AI Assistant powered by Professor Sahil. Features smart AI responses, automation, moderation, and media tools.",
  "repository": "https://github.com/sahillume/Mathithibala_Bot",
  "keywords": [
    "whatsapp",
    "baileys",
    "bot",
    "ai",
    "automation",
    "mathithibala"
  ],

  "buildpacks": [
    {
      "url": "heroku/nodejs"
    }
  ],

  "scripts": {
    "start": "node index.js"
  },

  "env": {
    "SESSION_ID": {
      "description": "Session ID for Mathithibala Bot (Baileys session string)",
      "required": false
    },

    "PREFIX": {
      "description": "Bot command prefix (example: . or !)",
      "required": false,
      "value": "."
    },

    "OWNER_NUMBER": {
      "description": "Owner WhatsApp number (e.g. 27835515085)",
      "required": false
    }
  }
}
